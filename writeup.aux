\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces  Parameters are set to $\text  {Var}(X)=\text  {Var}(U)=\text  {Var}(Z_1)=\text  {Var}(Z_2)=1$, with $\beta =0.5$, $\text  {Cov}(X,U)=0.4$, $\text  {Cov}(Z_1,U)=0.1$, $\text  {Cov}(Z_2,U)=0.2$, $\text  {Cov}(X,Z_1)=-0.3$, and $\text  {Cov}(X,Z_2)=-0.5$. The figure shows, over a grid of $(\delta _1,\delta _2)$, whether the value $0.4$ lies within the identified set based on $Z_1$ alone, $Z_2$ alone, and their intersection. }}{4}{figure.2}\protected@file@percent }
\newlabel{fig:2Z_bounds}{{2}{4}{Parameters are set to $\text {Var}(X)=\text {Var}(U)=\text {Var}(Z_1)=\text {Var}(Z_2)=1$, with $\beta =0.5$, $\text {Cov}(X,U)=0.4$, $\text {Cov}(Z_1,U)=0.1$, $\text {Cov}(Z_2,U)=0.2$, $\text {Cov}(X,Z_1)=-0.3$, and $\text {Cov}(X,Z_2)=-0.5$. The figure shows, over a grid of $(\delta _1,\delta _2)$, whether the value $0.4$ lies within the identified set based on $Z_1$ alone, $Z_2$ alone, and their intersection}{figure.2}{}}
